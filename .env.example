SERPER_API_KEY=your_serper_api_key_here
# Used by SerperDevTool for live search/news.
# UI citation behavior:
# - News claims prefer clickable URLs/domains from Serper results
# - Local metric claims use [source: *.csv] chips

# Optional if you switch away from Ollama later:
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# GEMINI_API_KEY=your_gemini_key
# GROQ_API_KEY=your_groq_key

# Suppress CrewAI telemetry signal warning (harmless but noisy in threaded servers):
OTEL_SDK_DISABLED=true

# CrewAI agent/crew verbose output (set to true for debugging):
# CREW_VERBOSE=false

# Runtime mode (defaults to prod if unset/invalid):
# STOCKSAGE_APP_MODE=prod
# STOCKSAGE_APP_MODE=dev
#
# Dev stream source:
# STOCKSAGE_DEV_STREAM_MODE=mock   # Fast UI iteration (default in dev)
# STOCKSAGE_DEV_STREAM_MODE=live   # Real pipeline while staying in dev
