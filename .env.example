# ── LLM Model ──────────────────────────────────────────────
# Default: deepseek/deepseek-chat (cheapest, ~$0.01-0.05 per analysis)
# Fallback: gemini/gemini-2.5-flash (free tier)
#
# Other options:
#   gemini/gemini-2.5-flash           Free (10 RPM, 250 req/day)
#   groq/llama-3.3-70b-versatile      Free (tight token limits)
#   openai/gpt-4o-mini                ~$0.15/$0.60 per M tokens
#   ollama/qwen2.5:14b-instruct       Local only (needs Ollama running)
#
# LLM_MODEL=deepseek/deepseek-chat
# LLM_FALLBACK_MODEL=gemini/gemini-2.5-flash

# ── API Keys ──────────────────────────────────────────────
# Set the key for whichever provider you chose above.
# LiteLLM auto-detects these env vars.

# DEEPSEEK_API_KEY=your_deepseek_key          # https://platform.deepseek.com
# GEMINI_API_KEY=your_gemini_key              # https://aistudio.google.com
# GROQ_API_KEY=your_groq_key                 # https://console.groq.com
# OPENAI_API_KEY=your_openai_key             # https://platform.openai.com

SERPER_API_KEY=your_serper_api_key_here
# Used by SerperDevTool for live news search.

# ── Telemetry / Crew ──────────────────────────────────────
OTEL_SDK_DISABLED=true
# CREW_VERBOSE=false

# ── App Mode ──────────────────────────────────────────────
# STOCKSAGE_APP_MODE=prod
# STOCKSAGE_APP_MODE=dev
# STOCKSAGE_DEV_STREAM_MODE=mock
# STOCKSAGE_DEV_STREAM_MODE=live
